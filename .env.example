# ============================================================
# 飞书会议总结 Skill - 环境变量示例文件
# ============================================================
# 复制此文件为 .env，并填写实际值
# 敏感信息（如 App Secret）建议通过环境变量注入，不写入配置文件
# ============================================================

# ---------- 飞书应用配置 ----------
# 飞书开放平台 → 企业自建应用 → 凭证管理
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- 用户角色配置 ----------
# 决策者 open_id（发送预览、接收战略决策）
# 获取方式：飞书 → 点击用户头像 → 复制 open_id
DECISION_MAKER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 日程组织者 open_id（用于权限过滤，只处理此人创建的日程/妙记）
# 通常与 DECISION_MAKER_OPEN_ID 相同
ORGANIZER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- LLM API 配置 ----------
# LLM API 地址（支持格式：localhost:8000 / http://localhost:8000 / https://xxx.com）
LLM_ENDPOINT=localhost:8000

# LLM 模型名称（需与 API 服务支持的模型匹配）
LLM_MODEL=qwen3.5-397b

# ---------- 多维表格配置（可选） ----------
# 会议任务管理表 base token（从多维表格 URL 获取）
MEETING_TASK_BASE_TOKEN=xxxxxxxxxxxxxxxxxxxx

# 会议任务管理表 table ID
MEETING_TASK_TABLE_ID=tblxxxxxxxxxxxx

# ---------- 其他配置（可选） ----------
# 妙记检查窗口（分钟，默认 60）
CHECK_WINDOW_MINUTES=60

# 任务到期前提醒天数（默认 3）
REMINDER_DAYS_BEFORE=3

# ============================================================
# 使用说明
# ============================================================
# 1. 复制此文件：cp .env.example .env
# 2. 填写实际值（不要提交 .env 到 Git）
# 3. 环境变量优先级高于 config.yaml / config.json
# ============================================================
